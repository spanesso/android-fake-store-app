# Reglas de estilo del proyecto Mango Fake Store. Las usa ktlint y los IDEs (Android Studio,
# IntelliJ, VS Code) para mantener formato consistente.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 120
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true
ij_kotlin_packages_to_use_import_on_demand = unset
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_filename = enabled
ktlint_standard_function-naming = disabled  # los Composables se nombran en PascalCase.
ktlint_standard_max-line-length = enabled

[*.{xml,yml,yaml,json,toml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
