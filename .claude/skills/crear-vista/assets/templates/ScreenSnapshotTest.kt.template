package {{paqueteRaiz}}.ui.screens

import app.cash.paparazzi.DeviceConfig
import app.cash.paparazzi.Paparazzi
import com.android.resources.NightMode
import com.mango.fakestore.core.designsystem.tema.MangoTema
import com.mango.fakestore.core.error.UiError
import org.junit.Rule
import org.junit.Test

/**
 * Snapshot tests para cada estado de la pantalla `{{Nombre}}` en modo claro y oscuro.
 * Las imágenes de referencia viven en `src/test/snapshots/images/`.
 */
class {{Nombre}}ScreenSnapshotTest {

    @get:Rule
    val paparazzi = Paparazzi(deviceConfig = DeviceConfig.PIXEL_5)

    @Test
    fun loading_claro() {
        paparazzi.snapshot {
            MangoTema { {{Nombre}}Screen(state = {{Nombre}}UiState.Loading, onEvent = {}) }
        }
    }

    @Test
    fun loading_oscuro() {
        paparazzi.unsafeUpdateConfig(deviceConfig = DeviceConfig.PIXEL_5.copy(nightMode = NightMode.NIGHT))
        paparazzi.snapshot {
            MangoTema { {{Nombre}}Screen(state = {{Nombre}}UiState.Loading, onEvent = {}) }
        }
    }

    @Test
    fun empty_claro() {
        paparazzi.snapshot {
            MangoTema { {{Nombre}}Screen(state = {{Nombre}}UiState.Empty, onEvent = {}) }
        }
    }

    @Test
    fun error_claro() {
        paparazzi.snapshot {
            MangoTema {
                {{Nombre}}Screen(
                    state = {{Nombre}}UiState.Error(uiError = UiError.previewSinConexion()),
                    onEvent = {},
                )
            }
        }
    }

    @Test
    fun content_claro() {
        paparazzi.snapshot {
            MangoTema { {{Nombre}}Screen(state = {{Nombre}}UiState.Content(), onEvent = {}) }
        }
    }
}
