<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">fakestoreapi.com</domain>
        <!--
            Verificado: 2026-05-12. Rotar antes de 2027-06-01.
            Primario: certificado hoja de fakestoreapi.com (Let's Encrypt, ~90 días).
            Backup: CA intermedia Google Trust Services WE1 (más estable).
            Verificar con: openssl s_client -connect fakestoreapi.com:443 -showcerts
        -->
        <pin-set expiration="2027-06-01">
            <!-- Pin primario — SHA-256 SPKI del certificado hoja de fakestoreapi.com -->
            <pin digest="SHA-256">dSxOWQR+hD1HkfYEk0y+JuXzHrLTjhVPXDzGRsbO7oI=</pin>
            <!--
                Pin de backup — SHA-256 SPKI de la CA intermedia Google Trust Services WE1.
                Más estable que el certificado hoja.
            -->
            <pin digest="SHA-256">kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4=</pin>
        </pin-set>
    </domain-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
